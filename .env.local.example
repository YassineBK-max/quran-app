# Copy this file to .env.local and fill in your credentials

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# URL of your app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials (from https://console.cloud.google.com)
# Authorized redirect URI to add: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Supabase — from supabase.com → Project Settings → API
# Used for live activity feed (Realtime Broadcast + Presence). No tables needed.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
